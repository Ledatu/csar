# CSAR Production Single-Node Environment Variables
# Copy to .env and fill in real values

# TLS certificates
CSAR_TLS_CERT_FILE=/etc/csar/tls/server-cert.pem
CSAR_TLS_KEY_FILE=/etc/csar/tls/server-key.pem
# CSAR_TLS_CLIENT_CA_FILE=/etc/csar/tls/client-ca.pem  # for mTLS

# KMS provider (yandexapi for Yandex Cloud)
CSAR_KMS_PROVIDER=yandexapi
CSAR_KMS_KEY_ID=your-kms-key-id

# Upstream target
CSAR_UPSTREAM_URL=https://your-upstream.internal

# Metrics
CSAR_METRICS_ADDR=:9100
