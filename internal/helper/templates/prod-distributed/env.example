# CSAR Production Distributed Environment Variables
# Copy to .env and fill in real values

# TLS certificates
CSAR_TLS_CERT_FILE=/etc/csar/tls/server-cert.pem
CSAR_TLS_KEY_FILE=/etc/csar/tls/server-key.pem

# KMS provider
CSAR_KMS_PROVIDER=yandexapi
CSAR_KMS_KEY_ID=your-kms-key-id

# Coordinator connection (gRPC + TLS)
CSAR_COORDINATOR_ADDRESS=coordinator.internal:9090
CSAR_COORDINATOR_CA_FILE=/etc/csar/tls/coordinator-ca.pem
CSAR_COORDINATOR_CERT_FILE=/etc/csar/tls/router-client-cert.pem
CSAR_COORDINATOR_KEY_FILE=/etc/csar/tls/router-client-key.pem

# Upstream targets
CSAR_UPSTREAM_URL=https://api-node1.internal
CSAR_UPSTREAM_URL_2=https://api-node2.internal

# Token store DSN (for coordinator)
CSAR_TOKEN_STORE_DSN=postgres://csar:password@db.internal:5432/csar?sslmode=require

# Metrics
CSAR_METRICS_ADDR=:9100
