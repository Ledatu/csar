# syntax=docker/dockerfile:1
FROM golang:1.25-alpine AS builder

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build -o /mockapi ./cmd/mockapi

# ---
FROM alpine:3.21
COPY --from=builder /mockapi /usr/local/bin/mockapi
ENV PORT=9999
EXPOSE 9999
ENTRYPOINT ["mockapi"]
